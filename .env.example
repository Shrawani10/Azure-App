# ============================================================
# Kisan Chat — Environment Variables
# ============================================================
# 1. Copy this file to .env  →  cp .env.example .env
# 2. Fill in your values below
# 3. Run locally with:        →  vercel dev
# ============================================================
# NOTE: These variables have NO VITE_ prefix intentionally.
# They are server-side only and never exposed to the browser.
# ============================================================

# REQUIRED: Azure OpenAI chat completions endpoint (full URL)
API_ENDPOINT=https://<resource>.services.ai.azure.com/openai/deployments/<deployment-name>/chat/completions?api-version=2024-10-21

# REQUIRED: Azure OpenAI API key
API_KEY=your-api-key-here

# OPTIONAL: Azure AI Search (for RAG — leave blank to disable)
SEARCH_ENDPOINT=https://<search-resource>.search.windows.net
SEARCH_INDEX=your-index-name
SEARCH_KEY=your-search-key-here
