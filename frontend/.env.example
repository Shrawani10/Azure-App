# ============================================================
# Kisan Chat — Azure OpenAI Configuration
# ============================================================
# 1. Copy this file to .env  →  cp .env.example .env
# 2. Fill in your values below
# 3. Restart the dev server   →  npm run dev
# ============================================================

# REQUIRED: Azure OpenAI chat completions endpoint (relative path — proxied via Vite)
VITE_API_ENDPOINT=/azure/openai/deployments/<deployment-name>/chat/completions?api-version=2024-10-21

# REQUIRED: Azure OpenAI API key
VITE_API_KEY=your-api-key-here

# REQUIRED: Azure OpenAI base URL (used by Vite proxy to forward /azure/* requests)
VITE_API_BASE_URL=https://<resource>.services.ai.azure.com

# OPTIONAL: Azure AI Search (for RAG — leave blank to disable)
VITE_SEARCH_ENDPOINT=https://<search-resource>.search.windows.net
VITE_SEARCH_INDEX=your-index-name
VITE_SEARCH_KEY=your-search-key-here
