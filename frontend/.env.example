# ============================================================
# Kisan Chat — Local Development Configuration
# ============================================================
# 1. Copy this file to .env  →  cp .env.example .env
# 2. Fill in your values below
# 3. Restart the dev server   →  npm run dev
#
# NOTE: In production (Vercel), set API_KEY, API_ENDPOINT,
# SEARCH_ENDPOINT, SEARCH_INDEX, SEARCH_KEY as environment
# variables in the Vercel dashboard (without VITE_ prefix).
# They are used by the serverless function and never exposed
# to the browser.
# ============================================================

# REQUIRED: Full Azure OpenAI endpoint URL
# Example: https://<resource>.services.ai.azure.com/openai/deployments/<deployment>/chat/completions?api-version=2024-10-21
VITE_API_ENDPOINT=https://<resource>.services.ai.azure.com/openai/deployments/<deployment-name>/chat/completions?api-version=2024-10-21

# REQUIRED: Azure OpenAI API key (local dev only — use Vercel env vars in production)
VITE_API_KEY=your-api-key-here

# OPTIONAL: Azure AI Search (for RAG — leave blank to disable)
VITE_SEARCH_ENDPOINT=https://<search-resource>.search.windows.net
VITE_SEARCH_INDEX=your-index-name
VITE_SEARCH_KEY=your-search-key-here
